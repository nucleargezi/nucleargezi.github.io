---
import "../styles/base.css";
import "../styles/layout.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  pageClass?: string;
  hideHeader?: boolean;
}

const { title, description, lang = "zh-CN", pageClass, hideHeader = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <div class="site-shell">
      {
        !hideHeader && (
          <header class="site-header">
            <a class="site-title" href="/">Yorisou Realm</a>
            <nav class="site-nav" aria-label="Primary">
              <!-- <a href="/">首页</a> -->

              <a href="/article/">Article</a>

              <a href="/article/personal-info">About</a>
            </nav>
          </header>
        )
      }

      <main class:list={["page", pageClass]}>
        <slot />
      </main>
    </div>
  </body>
</html>
