---
import BaseLayout from "./BaseLayout.astro";
import "../styles/post.css";
import {
  type TocHeading,
  formatDate,
  normalizeDescription,
  toHtmlLang,
} from "../lib/blog";

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: unknown;
  lang?: string;
  region?: string;
  toc?: TocHeading[];
}

const {
  title,
  date,
  tags = [],
  description,
  lang,
  region,
  toc = [],
} = Astro.props;

const descriptionText = normalizeDescription(description);
---

<BaseLayout
  title={title}
  description={descriptionText}
  lang={toHtmlLang(lang, region)}
  pageClass="page-post"
>
  <article class="post">
    <header class="post-header">
      <!-- <p class="eyebrow">Article</p> -->
      <div class="post-meta">
        <time datetime={formatDate(date)}>{formatDate(date)} ·✎</time>
      </div>
      <h1 class="post-title">{title}</h1>
      {descriptionText && <p class="post-description">{descriptionText}</p>}
      <!-- {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      } -->
    </header>

    {
      toc.length > 0 && (
        <nav class="post-toc" aria-label="Table of contents">
          <p class="post-toc-title">Constent</p>
          <ol class="post-toc-list">
            {toc.map((item) => (
              <li class={`post-toc-item toc-level-${item.level}`}>
                <a
                  class="toc-link"
                  href={`#${item.id}`}
                  data-heading-id={item.id}
                  data-heading-title={item.title}
                >
                  {item.title}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="post-body">
      <slot />
    </div>
  </article>
  <script is:inline>
    const normalizeTocText = (value) => value.replace(/\s+/g, " ").trim();
    const compactTocText = (value) => normalizeTocText(value).replace(/\s+/g, "");
    const isHeadingNumber = (value) => /^\d+(?:\.\d+)*\.$/.test(value);

    const buildHeadingTargets = () => {
      const tocLinks = [...document.querySelectorAll(".toc-link")];
      const textNodes = [...document.querySelectorAll(".post-body .typst-doc .tsel")]
        .map((node) => ({
          node,
          text: normalizeTocText(node.textContent ?? ""),
        }))
        .filter((item) => item.text.length > 0);

      const targets = new Map();
      let cursor = 0;

      for (const link of tocLinks) {
        const headingId = link.dataset.headingId ?? "";
        const targetText = compactTocText(link.dataset.headingTitle ?? "");
        if (!headingId || !targetText) {
          continue;
        }

        for (let start = cursor; start < textNodes.length; start += 1) {
          let combined = "";
          let anchorNode = null;
          let matched = false;

          for (let end = start; end < Math.min(textNodes.length, start + 12); end += 1) {
            const segment = textNodes[end].text;

            if (!anchorNode && isHeadingNumber(segment)) {
              continue;
            }

            if (!anchorNode) {
              anchorNode = textNodes[end].node;
            }

            combined += compactTocText(segment);

            if (!targetText.startsWith(combined)) {
              break;
            }

            if (combined === targetText) {
              targets.set(headingId, anchorNode);
              cursor = end + 1;
              matched = true;
              break;
            }
          }

          if (matched) {
            break;
          }
        }
      }

      return targets;
    };

    const headingTargets = buildHeadingTargets();

    const scrollToHeading = (link, behavior) => {
      const headingId = link.dataset.headingId ?? "";
      const target = headingTargets.get(headingId);

      if (!target) {
        return false;
      }

      const top = target.getBoundingClientRect().top + window.scrollY - 24;
      window.scrollTo({ top, behavior });
      history.replaceState(null, "", link.getAttribute("href") ?? "");
      return true;
    };

    document.addEventListener("click", (event) => {
      const link = event.target.closest(".toc-link");
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      event.preventDefault();
      scrollToHeading(link, "smooth");
    });

    window.addEventListener("load", () => {
      if (!location.hash.startsWith("#heading-")) {
        return;
      }

      const link = document.querySelector(`.toc-link[href="${location.hash}"]`);
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      requestAnimationFrame(() => {
        scrollToHeading(link, "auto");
      });
    });
  </script>
</BaseLayout>
