---
import BaseLayout from "./BaseLayout.astro";
import "../styles/post.css";
import {
  type TocHeading,
  formatDate,
  normalizeDescription,
  toHtmlLang,
} from "../lib/blog";

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: unknown;
  lang?: string;
  region?: string;
  toc?: TocHeading[];
}

const {
  title,
  date,
  tags = [],
  description,
  lang,
  region,
  toc = [],
} = Astro.props;

const descriptionText = normalizeDescription(description);
---

<BaseLayout
  title={title}
  description={descriptionText}
  lang={toHtmlLang(lang, region)}
  pageClass="page-post"
>
  <article class="post">
    <header class="post-header">
      <!-- <p class="eyebrow">Article</p> -->
      <div class="post-meta">
        <time datetime={formatDate(date)}>{formatDate(date)}·✎</time>
      </div>
      <h1 class="post-title">{title}</h1>
      {descriptionText && <p class="post-description">{descriptionText}</p>}
      <!-- {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      } -->
    </header>

    {
      toc.length > 0 && (
        <nav class="post-toc" aria-label="Table of contents">
          <p class="post-toc-title">Constent</p>
          <ol class="post-toc-list">
            {toc.map((item) => (
              <li class={`post-toc-item toc-level-${item.level}`}>
                <a
                  class="toc-link"
                  href={`#${item.id}`}
                  data-heading-id={item.id}
                  data-heading-title={item.title}
                  data-heading-match-index={item.matchIndex}
                >
                  {item.title}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="post-body">
      <slot />
    </div>
  </article>
  <script is:inline>
    const normalizeTocText = (value) => value.replace(/\s+/g, " ").trim();

    const buildHeadingIndex = () => {
      const index = new Map();
      const nodes = document.querySelectorAll(".post-body .typst-doc .tsel");

      for (const node of nodes) {
        const text = normalizeTocText(node.textContent ?? "");
        if (!text) continue;

        const list = index.get(text) ?? [];
        list.push(node);
        index.set(text, list);
      }

      return index;
    };

    const headingIndex = buildHeadingIndex();

    const scrollToHeading = (link, behavior) => {
      const title = normalizeTocText(link.dataset.headingTitle ?? "");
      const matchIndex = Number(link.dataset.headingMatchIndex ?? "0");
      const candidates = headingIndex.get(title) ?? [];
      const target = candidates[matchIndex];

      if (!target) {
        return false;
      }

      const top = target.getBoundingClientRect().top + window.scrollY - 24;
      window.scrollTo({ top, behavior });
      history.replaceState(null, "", link.getAttribute("href") ?? "");
      return true;
    };

    document.addEventListener("click", (event) => {
      const link = event.target.closest(".toc-link");
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      event.preventDefault();
      scrollToHeading(link, "smooth");
    });

    window.addEventListener("load", () => {
      if (!location.hash.startsWith("#heading-")) {
        return;
      }

      const link = document.querySelector(`.toc-link[href="${location.hash}"]`);
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      requestAnimationFrame(() => {
        scrollToHeading(link, "auto");
      });
    });
  </script>
</BaseLayout>
