---
import BaseLayout from "./BaseLayout.astro";
import "../styles/post.css";
import {
  formatDate,
  normalizeDescription,
  toHtmlLang,
} from "../lib/blog";

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: unknown;
  lang?: string;
  region?: string;
}

const {
  title,
  date,
  tags = [],
  description,
  lang,
  region,
} = Astro.props;

const descriptionText = normalizeDescription(description);
---

<BaseLayout
  title={title}
  description={descriptionText}
  lang={toHtmlLang(lang, region)}
  pageClass="page-post"
>
  <article class="post">
    <header class="post-header">
      <p class="eyebrow">Article</p>
      <div class="post-meta">
        <time datetime={formatDate(date)}>{formatDate(date)}·✎</time>
      </div>
      <h1 class="post-title">{title}</h1>
      <!-- {descriptionText && <p class="post-description">{descriptionText}</p>} -->
      <!-- {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      } -->
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>
</BaseLayout>
