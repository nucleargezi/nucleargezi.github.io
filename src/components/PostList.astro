---
import type { CollectionEntry } from "astro:content";

import { formatDate, normalizeDescription } from "../lib/blog";

interface Props {
  posts: CollectionEntry<"blog">[];
  emptyText?: string;
  showTags?: boolean;
  tagBaseUrl?: string;
}

const {
  posts,
  emptyText = "还没有文章。",
  showTags = false,
  tagBaseUrl = "/article/",
} = Astro.props;
---

{
  posts.length === 0 ? (
    <p class="empty-state">{emptyText}</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => {
        const description = normalizeDescription(post.data.description);
        const tags = post.data.tags ?? [];

        return (
          <li
            class="post-list-item"
            data-tags={JSON.stringify(tags)}
          >
            <a class="post-list-link" href={`/article/${post.id}`}>
              <span class="post-list-title">{post.data.title}</span>
              <span class="post-list-date">{formatDate(post.data.date)}</span>
            </a>
            {showTags && tags.length > 0 && (
              <ul class="post-list-tags" aria-label="文章标签">
                {tags.map((tag) => (
                  <li>
                    <a
                      class="post-list-tag"
                      href={`${tagBaseUrl}?search=${encodeURIComponent(tag)}`}
                      data-tag={tag}
                    >
                      {tag}
                    </a>
                  </li>
                ))}
              </ul>
            )}
            {description && <p class="post-list-description">{description}</p>}
          </li>
        );
      })}
    </ul>
  )
}
