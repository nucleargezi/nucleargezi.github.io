---
import { getCollection } from "astro:content";

import PostList from "../../components/PostList.astro";
import TagFilterScript from "../../components/TagFilterScript.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortPosts } from "../../lib/blog";
import "../../styles/listing.css";

const posts = sortPosts(
  (await getCollection("blog")).filter((post) => post.data.category === "Algorithm"),
);
---

<BaseLayout title="Algorithm" description="Algorithm 分类下的全部文章。">
  <section>
    <h1 class="page-title">Algorithm</h1>
  </section>

  <section>
    <p class="article-filter-status" data-filter-status hidden></p>
    <p class="empty-state article-filter-empty" data-filter-empty hidden></p>
    <PostList
      posts={posts}
      emptyText="这个分类下还没有写好的文章。"
      showTags={true}
      tagBaseUrl="/algorithm/"
    />
  </section>
</BaseLayout>

<TagFilterScript baseUrl="/algorithm/" emptyText="这个分类下还没有写好的文章。" />
