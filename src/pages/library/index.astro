---
import LibraryTree from "../../components/LibraryTree.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLibraryPageData } from "../../lib/library-state";
import "../../styles/listing.css";
import "../../styles/library.css";

const library = await getLibraryPageData();

const serializedDetails = JSON.stringify(library.details).replace(/</g, "\\u003c");
---

<BaseLayout
  title="Library"
  description="Template coverage and test status for the local algorithm library."
  pageClass="page-library"
>
  <h1 class="page-title">Library</h1>

  <section class="library-summary-grid" aria-label="Library summary">
    <article class="library-summary-card">
      <p class="eyebrow">Templates</p>
      <h2 class="library-summary-title">Template Coverage</h2>
      <ul class="library-stat-list">
        <li class="library-stat-item">
          <span class="library-stat-label">Total files</span>
          <span class="library-stat-value">{library.summary.templates.total}</span>
        </li>
        <li class="library-stat-item">
          <span class="library-stat-label">All passed</span>
          <span class="library-stat-value is-pass">{library.summary.templates.allPassed}</span>
        </li>
        <li class="library-stat-item">
          <span class="library-stat-label">Has failures</span>
          <span class="library-stat-value is-fail">{library.summary.templates.hasFailures}</span>
        </li>
        <li class="library-stat-item">
          <span class="library-stat-label">No tests</span>
          <span class="library-stat-value is-unused">{library.summary.templates.unused}</span>
        </li>
      </ul>
    </article>

    <article class="library-summary-card">
      <p class="eyebrow">Tests</p>
      <h2 class="library-summary-title">Test Files</h2>
      <ul class="library-stat-list">
        <li class="library-stat-item">
          <span class="library-stat-label">Total files</span>
          <span class="library-stat-value">{library.summary.tests.total}</span>
        </li>
        <li class="library-stat-item">
          <span class="library-stat-label">Passed</span>
          <span class="library-stat-value is-pass">{library.summary.tests.passed}</span>
        </li>
        <li class="library-stat-item">
          <span class="library-stat-label">Failed</span>
          <span class="library-stat-value is-fail">{library.summary.tests.notPassed}</span>
        </li>
      </ul>
    </article>
  </section>

  <section class="library-panels" aria-label="Library trees">
    <section class="library-panel">
      <div class="section-header library-panel-heading">
        <h2 class="section-title">Template Coverage</h2>
        <p class="library-panel-count">{library.summary.templates.total} files</p>
      </div>
      <div class="library-legend" aria-label="Template status legend">
        <span class="library-legend-item is-pass">
          <span class="library-legend-dot" aria-hidden="true"></span>
          All passed
        </span>
        <span class="library-legend-item is-fail">
          <span class="library-legend-dot" aria-hidden="true"></span>
          Has failures
        </span>
        <span class="library-legend-item is-unused">
          <span class="library-legend-dot" aria-hidden="true"></span>
          No tests
        </span>
      </div>
      <LibraryTree
        tree={library.templateTree}
        ariaLabel="Template coverage tree"
      />
    </section>

    <section class="library-panel">
      <div class="section-header library-panel-heading">
        <h2 class="section-title">Tests</h2>
        <p class="library-panel-count">{library.summary.tests.total} files</p>
      </div>
      <div class="library-legend" aria-label="Test status legend">
        <span class="library-legend-item is-pass">
          <span class="library-legend-dot" aria-hidden="true"></span>
          Passed
        </span>
        <span class="library-legend-item is-fail">
          <span class="library-legend-dot" aria-hidden="true"></span>
          Not passed
        </span>
      </div>
      <LibraryTree
        tree={library.testTree}
        ariaLabel="Test file tree"
      />
    </section>
  </section>

  <section
    class="library-detail-modal"
    data-library-detail-modal
    hidden
    aria-hidden="true"
  >
    <section
      class="library-detail-dialog"
      data-library-detail-dialog
      aria-live="polite"
      aria-label="Library detail"
    >
      <p class="eyebrow" data-library-detail-kicker>Library</p>
      <h2 class="library-detail-title" data-library-detail-title>
        Select a file to inspect its coverage details.
      </h2>
      <p class="library-detail-summary" data-library-detail-summary>No file selected.</p>

      <ul class="library-detail-meta" data-library-detail-meta hidden></ul>

      <section class="library-detail-related" data-library-detail-primary-section hidden>
        <h3 class="library-detail-related-title" data-library-detail-primary-title>Related Files</h3>
        <ul class="library-detail-related-list" data-library-detail-primary-list></ul>
      </section>

      <section class="library-detail-related" data-library-detail-secondary-section hidden>
        <h3 class="library-detail-related-title" data-library-detail-secondary-title>Related Files</h3>
        <ul class="library-detail-related-list" data-library-detail-secondary-list></ul>
      </section>
    </section>
  </section>

  <script type="application/json" id="library-details" set:html={serializedDetails}></script>

  <script is:inline>
    const detailSource = document.getElementById("library-details");
    const detailMap = detailSource ? JSON.parse(detailSource.textContent ?? "{}") : {};
    const statusLabels = {
      all_passed: "All tests passed",
      has_failures: "Contains failing test coverage",
      unused: "No tests recorded",
      passed: "Passed",
      not_passed: "Not passed",
    };
    const kindLabels = {
      template: "Template",
      test: "Test",
    };
    const detailSections = {
      template: [
        {
          title: "Template Dependencies",
          empty: "No template dependencies recorded.",
          getPaths: (detail) => Array.isArray(detail.dependencies) ? detail.dependencies : [],
        },
        {
          title: "Related Tests",
          empty: "No related tests recorded.",
          getPaths: (detail) => Array.isArray(detail.relatedTests) ? detail.relatedTests : [],
        },
      ],
      test: [
        {
          title: "Template Dependencies",
          empty: "No template dependencies recorded.",
          getPaths: (detail) => Array.isArray(detail.relatedTemplates) ? detail.relatedTemplates : [],
        },
      ],
    };

    const buttons = [...document.querySelectorAll("[data-library-tree-button]")];
    const buttonByDetailId = new Map(
      buttons
        .map((button) => [button.dataset.detailId, button])
        .filter(([detailId]) => typeof detailId === "string"),
    );
    const detailIndexByPath = new Map(
      Object.entries(detailMap)
        .filter(([, detail]) => detail && typeof detail.path === "string")
        .map(([detailId, detail]) => [
          detail.path,
          { detailId, kind: detail.kind, status: detail.status },
        ]),
    );
    const modalElement = document.querySelector("[data-library-detail-modal]");
    const dialogElement = document.querySelector("[data-library-detail-dialog]");
    const kickerElement = document.querySelector("[data-library-detail-kicker]");
    const titleElement = document.querySelector("[data-library-detail-title]");
    const summaryElement = document.querySelector("[data-library-detail-summary]");
    const metaElement = document.querySelector("[data-library-detail-meta]");
    const primarySectionElement = document.querySelector("[data-library-detail-primary-section]");
    const primaryTitleElement = document.querySelector("[data-library-detail-primary-title]");
    const primaryListElement = document.querySelector("[data-library-detail-primary-list]");
    const secondarySectionElement = document.querySelector("[data-library-detail-secondary-section]");
    const secondaryTitleElement = document.querySelector("[data-library-detail-secondary-title]");
    const secondaryListElement = document.querySelector("[data-library-detail-secondary-list]");

    const updateSelection = (activeDetailId) => {
      const activeButton = activeDetailId ? buttonByDetailId.get(activeDetailId) ?? null : null;

      for (const candidate of buttons) {
        const isSelected = candidate === activeButton;
        candidate.classList.toggle("is-selected", isSelected);
        candidate.setAttribute("aria-pressed", isSelected ? "true" : "false");
      }
    };

    const createMetaItem = (label, value) => {
      const item = document.createElement("li");
      item.className = "library-detail-meta-item";

      const labelElement = document.createElement("span");
      labelElement.className = "library-detail-meta-label";
      labelElement.textContent = label;

      const valueElement = document.createElement("span");
      valueElement.className = "library-detail-meta-value";
      valueElement.textContent = value;

      item.append(labelElement, valueElement);
      return item;
    };

    const hideListSection = (sectionElement, listElement) => {
      if (sectionElement) {
        sectionElement.hidden = true;
      }

      if (listElement) {
        listElement.textContent = "";
      }
    };

    const createEmptyListItem = (label) => {
      const item = document.createElement("li");
      item.className = "library-detail-related-item is-empty";
      item.textContent = label;
      return item;
    };

    const createDetailLink = (path) => {
      const detailIndex = detailIndexByPath.get(path);
      if (!detailIndex) {
        const item = document.createElement("li");
        item.className = "library-detail-related-item";
        item.textContent = path;
        return item;
      }

      const item = document.createElement("li");
      item.className = "library-detail-related-item";

      const button = document.createElement("button");
      button.type = "button";
      button.className = "library-detail-related-button";
      button.dataset.detailId = detailIndex.detailId;
      button.dataset.kind = detailIndex.kind;
      button.dataset.status = detailIndex.status;
      button.textContent = path;
      button.addEventListener("click", () => {
        openDetail(detailIndex.detailId);
      });

      item.append(button);
      return item;
    };

    const renderListSection = (sectionElement, titleElement, listElement, config, paths) => {
      if (!sectionElement || !titleElement || !listElement || !config) {
        return;
      }

      sectionElement.hidden = false;
      titleElement.textContent = config.title;
      listElement.textContent = "";

      if (paths.length === 0) {
        listElement.append(createEmptyListItem(config.empty));
        return;
      }

      for (const path of paths) {
        listElement.append(createDetailLink(path));
      }
    };

    const renderDetail = (detailId) => {
      const detail = detailMap[detailId];
      if (!detail || !kickerElement || !titleElement || !summaryElement) {
        return;
      }

      kickerElement.textContent = kindLabels[detail.kind];
      titleElement.textContent = detail.path;
      summaryElement.textContent = statusLabels[detail.status] ?? detail.status;

      if (metaElement) {
        metaElement.textContent = "";

        if (detail.kind === "test" && Array.isArray(detail.meta)) {
          for (const { label, value } of detail.meta) {
            metaElement.append(createMetaItem(label, value));
          }

          metaElement.hidden = detail.meta.length === 0;
        } else {
          metaElement.hidden = true;
        }
      }

      const [primarySection, secondarySection] = detailSections[detail.kind] ?? [];
      renderListSection(
        primarySectionElement,
        primaryTitleElement,
        primaryListElement,
        primarySection,
        primarySection ? primarySection.getPaths(detail) : [],
      );

      if (secondarySection) {
        renderListSection(
          secondarySectionElement,
          secondaryTitleElement,
          secondaryListElement,
          secondarySection,
          secondarySection.getPaths(detail),
        );
      } else {
        hideListSection(secondarySectionElement, secondaryListElement);
      }
    };

    const closeModal = () => {
      if (!modalElement) {
        return;
      }

      modalElement.hidden = true;
      modalElement.setAttribute("aria-hidden", "true");
      updateSelection(null);
    };

    const openDetail = (detailId) => {
      if (!detailId || !modalElement) {
        return;
      }

      updateSelection(detailId);
      renderDetail(detailId);
      modalElement.hidden = false;
      modalElement.setAttribute("aria-hidden", "false");
    };

    for (const button of buttons) {
      button.addEventListener("click", () => {
        openDetail(button.dataset.detailId);
      });
    }

    if (modalElement) {
      modalElement.addEventListener("click", closeModal);
    }

    if (dialogElement) {
      dialogElement.addEventListener("click", (event) => {
        event.stopPropagation();
      });
    }
  </script>
</BaseLayout>
