---
import { getCollection } from "astro:content";

import PostList from "../../components/PostList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortPosts } from "../../lib/blog";
import "../../styles/listing.css";

const posts = sortPosts(await getCollection("blog"));
---

<BaseLayout title="Articles" description="这个站点当前的全部 Typst 文章。">
  <section>
    <!-- <p class="eyebrow">Articles</p> -->
    <h1 class="page-title">List</h1>
  </section>

  <section>
    <p class="article-filter-status" data-filter-status hidden></p>
    <p class="empty-state article-filter-empty" data-filter-empty hidden></p>
    <PostList
      posts={posts}
      emptyText="还没有写好的文章。"
      showTags={true}
      tagBaseUrl="/article/"
    />
  </section>
</BaseLayout>

<script is:inline>
  const filterStatus = document.querySelector("[data-filter-status]");
  const filterEmpty = document.querySelector("[data-filter-empty]");
  const postItems = [...document.querySelectorAll(".post-list-item")];

  const parseSearchTags = () => {
    const params = new URLSearchParams(window.location.search);
    const raw = params.get("search") ?? "";
    return [...new Set(raw.split(/\s+/).map((tag) => tag.trim()).filter(Boolean))];
  };

  const updateTagLinks = (selectedTags) => {
    for (const tagLink of document.querySelectorAll(".post-list-tag")) {
      const tag = tagLink.dataset.tag;
      if (!tag) {
        continue;
      }

      const isActive = selectedTags.includes(tag);
      const nextTags = isActive
        ? selectedTags.filter((selectedTag) => selectedTag !== tag)
        : [...selectedTags, tag];
      const params = new URLSearchParams(window.location.search);

      if (nextTags.length === 0) {
        params.delete("search");
      } else {
        params.set("search", nextTags.join(" "));
      }

      const query = params.toString();
      tagLink.href = query ? `/article/?${query}` : "/article/";
      tagLink.classList.toggle("is-active", isActive);
    }
  };

  const applyFilter = () => {
    const selectedTags = parseSearchTags();
    let visibleCount = 0;

    for (const item of postItems) {
      const itemTags = JSON.parse(item.dataset.tags ?? "[]");
      const matches =
        selectedTags.length === 0 ||
        selectedTags.every((tag) => itemTags.includes(tag));

      item.toggleAttribute("hidden", !matches);
      if (matches) {
        visibleCount += 1;
      }
    }

    updateTagLinks(selectedTags);

    if (filterStatus) {
      if (selectedTags.length === 0) {
        filterStatus.hidden = true;
        filterStatus.textContent = "";
      } else {
        filterStatus.hidden = false;
        filterStatus.textContent = `Tag: #${selectedTags.join(" + #")}`;
      }
    }

    if (filterEmpty) {
      filterEmpty.hidden = visibleCount !== 0;
      filterEmpty.textContent =
        selectedTags.length === 0
          ? "还没有写好的文章。"
          : `没有同时带有 ${selectedTags.join(" + ")} 的文章。`;
    }
  };

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) {
      return;
    }

    const tagLink = event.target.closest(".post-list-tag");
    if (!(tagLink instanceof HTMLAnchorElement)) {
      return;
    }

    event.preventDefault();
    window.history.pushState({}, "", tagLink.href);
    applyFilter();
  });

  window.addEventListener("popstate", applyFilter);
  applyFilter();
</script>
